{
  "name": "halfline",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "dev:web": "turbo dev --filter=@halfline/web",
    "dev:mobile": "turbo dev --filter=@halfline/mobile",
    "dev:extension": "turbo dev --filter=@halfline/extension",
    "build:web": "turbo build --filter=@halfline/web"
  },
  "devDependencies": {
    "turbo": "^2.10.2",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.9.0"
  }
}
